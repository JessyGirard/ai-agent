      "headers": {},
      "payload": {},
      "timeout_seconds": 25,
      "assertions": {
        "expected_status": 200,
        "body_contains": "\"userId\":"
      }
    },
    {
      "name": "Header check — JSON content type present",
      "method": "GET",
      "url": "https://jsonplaceholder.typicode.com/posts/1",
      "headers": {},
      "payload": {},
      "timeout_seconds": 25,
      "assertions": {
        "expected_status": 200,
        "header_contains": "application/json"
      }
    }
  ]
}
