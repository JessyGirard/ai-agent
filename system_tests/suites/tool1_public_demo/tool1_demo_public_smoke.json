{
  "suite_name": "Tool 1 demo — public API smoke",
  "target_name": "jsonplaceholder.typicode.com",
  "cases": [
    {
      "name": "Smoke — GET post returns 200",
      "method": "GET",
      "url": "https://jsonplaceholder.typicode.com/posts/1",
      "headers": {},
      "payload": {},
      "timeout_seconds": 25,
      "assertions": {
