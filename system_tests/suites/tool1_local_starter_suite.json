{
  "suite_name": "tool1-local-starter",
  "target_name": "tool1-verify-localhost",
  "cases": [
    {
      "name": "basic-health-check",
      "lane": "stability",
      "stability_attempts": 3,
      "method": "POST",
      "url": "http://127.0.0.1:37641/tool1/health",
      "headers": {},
      "payload": {
        "note": "ignored by verify server; body is fixed"
      },
      "timeout_seconds": 20,
      "assertions": {
        "status_code": 200,
        "contains_all": [
          "TOOL1_HEALTH_OK"
        ],
        "not_contains": [
          "TOOL1_ERROR"
        ]
      }
    },
    {
      "name": "structured-response-check",
      "lane": "correctness",
      "method": "POST",
      "url": "http://127.0.0.1:37641/tool1/structured",
      "headers": {},
      "payload": {},
      "timeout_seconds": 20,
      "assertions": {
        "status_code": 200,
        "contains_all": [
          "\"status\"",
          "\"message\""
        ],
        "regex": "\"status\"\\s*:\\s*\"[a-zA-Z_]+\""
      }
    },
    {
      "name": "consistency-sample-check",
      "lane": "consistency",
      "repeat_count": 3,
      "method": "POST",
      "url": "http://127.0.0.1:37641/tool1/consistent",
      "headers": {},
      "payload": {},
      "timeout_seconds": 20,
      "assertions": {
        "status_code": 200,
        "contains_all": [
          "TOOL1_CONSISTENCY_OK"
        ]
      }
    }
  ]
}
